{
	"compilerOptions": {
		"outDir": "../build",
		"sourceMap": true,
		"noImplicitAny": false,
		"module": "commonjs",
		"target": "es2019",
		"jsx": "react-jsx",
		"allowJs": true,
		"moduleResolution": "node",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"lib": [ "dom", "es2019", "scripthost" ],
		"ignoreDeprecations": "6.0"
	}
}
